{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "url": "data/climate.json"
  },
  "transform": [
    {
      "filter": "datum.route === 'Gibb River Road'"
    }
  ],
  "width": 440,
  "height": 440,
  "layer": [
    {
      "mark": {
        "type": "arc",
        "innerRadius": 80,
        "outerRadius": 180,
        "stroke": "white",
        "strokeWidth": 3
      },
      "encoding": {
        "theta": {
          "field": "month",
          "type": "nominal",
          "sort": [
            "Jan",
            "Feb",
            "Mar",
            "Apr",
            "May",
            "Jun",
            "Jul",
            "Aug",
            "Sep",
            "Oct",
            "Nov",
            "Dec"
          ]
        },
        "color": {
          "field": "rating",
          "type": "nominal",
          "title": "Drive rating",
          "scale": {
            "domain": [
              "Ideal",
              "OK",
              "Avoid"
            ],
            "range": [
              "#1F7A3F",
              "#E8B83A",
              "#C84031"
            ]
          },
          "legend": {
            "orient": "right",
            "titleFontSize": 12,
            "labelFontSize": 11,
            "symbolSize": 150
          }
        },
        "tooltip": [
          {
            "field": "month",
            "type": "nominal",
            "title": "Month"
          },
          {
            "field": "max_temp",
            "type": "quantitative",
            "title": "Max temp (\u00b0C)"
          },
          {
            "field": "rainfall",
            "type": "quantitative",
            "title": "Rainfall (mm)"
          },
          {
            "field": "drive_score",
            "type": "quantitative",
            "title": "Drive score"
          },
          {
            "field": "rating",
            "type": "nominal",
            "title": "Rating"
          },
          {
            "field": "reason",
            "type": "nominal",
            "title": "Why"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "radius": 200,
        "fontSize": 14,
        "fontWeight": "bold",
        "color": "#333"
      },
      "encoding": {
        "theta": {
          "field": "month",
          "type": "nominal",
          "sort": [
            "Jan",
            "Feb",
            "Mar",
            "Apr",
            "May",
            "Jun",
            "Jul",
            "Aug",
            "Sep",
            "Oct",
            "Nov",
            "Dec"
          ]
        },
        "text": {
          "field": "month"
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "radius": 130,
        "fontSize": 12,
        "color": "white",
        "fontWeight": "bold"
      },
      "encoding": {
        "theta": {
          "field": "month",
          "type": "nominal",
          "sort": [
            "Jan",
            "Feb",
            "Mar",
            "Apr",
            "May",
            "Jun",
            "Jul",
            "Aug",
            "Sep",
            "Oct",
            "Nov",
            "Dec"
          ]
        },
        "text": {
          "field": "rainfall_label",
          "type": "nominal"
        }
      },
      "transform": [
        {
          "calculate": "datum.rainfall + 'mm'",
          "as": "rainfall_label"
        }
      ]
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Inter, sans-serif",
    "background": "transparent",
    "axis": {
      "labelFont": "Inter, sans-serif",
      "titleFont": "Inter, sans-serif",
      "labelColor": "#6B635A",
      "titleColor": "#2A2520",
      "labelFontSize": 11,
      "titleFontSize": 12,
      "domainColor": "#D8CFBE",
      "tickColor": "#D8CFBE",
      "gridColor": "#EDE7DC",
      "gridOpacity": 0.6
    },
    "legend": {
      "labelFont": "Inter, sans-serif",
      "titleFont": "Inter, sans-serif",
      "labelColor": "#2A2520",
      "titleColor": "#2A2520",
      "labelFontSize": 12,
      "titleFontSize": 12
    },
    "header": {
      "labelFont": "Inter, sans-serif",
      "titleFont": "Inter, sans-serif",
      "labelColor": "#2A2520"
    }
  }
}